# PANAS Ecosystem - Environment Variables
# ======================================

# Application
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database
DATABASE_URL=postgresql://panas_user:panas_password@localhost:5432/panas_db
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=panas_jwt_secret_key_2024
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:3000

# Blockchain
ALGORAND_ALGOD_URL=https://testnet-api.algonode.cloud
ALGORAND_INDEXER_URL=https://testnet-idx.algonode.cloud
ALGORAND_ACCOUNT_MNEMONIC=your_mnemonic_here
ALGORAND_ALGOD_TOKEN=your_token_here

SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WALLET_PATH=~/.config/solana/id.json

ETHEREUM_RPC_URL=https://sepolia.infura.io/v3/your_project_id
ETHEREUM_PRIVATE_KEY=your_private_key_here

TON_API_URL=https://testnet.toncenter.com/api/v2
TON_WALLET_MNEMONIC=your_mnemonic_here

# AI Services
OPENAI_API_KEY=your_openai_api_key
HUGGINGFACE_API_KEY=your_huggingface_token
ANTHROPIC_API_KEY=your_anthropic_api_key

# Bots
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook/telegram

DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# External APIs
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET_KEY=your_binance_secret_key

GOOGLE_API_KEY=your_google_api_key
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Deployment
HEROKU_APP_NAME=panas-app-name
VERCEL_PROJECT_ID=your_vercel_project_id
VERCEL_TOKEN=your_vercel_token

# Monitoring
SENTRY_DSN=your_sentry_dsn
LOG_LEVEL=info
