{
  "name": "Staging Environment",
  "environment": "staging",
  "debug": true,
  "logging": {
    "level": "debug",
    "console": true,
    "file": true,
    "filePath": "./logs/staging.log"
  },
  "database": {
    "host": "${DB_HOST}",
    "port": "${DB_PORT}",
    "name": "${DB_NAME}",
    "user": "${DB_USER}",
    "password": "${DB_PASSWORD}",
    "ssl": true
  },
  "redis": {
    "host": "${REDIS_HOST}",
    "port": "${REDIS_PORT}",
    "password": "${REDIS_PASSWORD}",
    "db": 0
  },
  "api": {
    "port": "${PORT}",
    "cors": {
      "origin": ["https://staging.panacea-icono.com", "https://staging.panas.panacea-icono.com"],
      "credentials": true
    },
    "rateLimit": {
      "windowMs": 900000,
      "max": 500
    }
  },
  "algorand": {
    "network": "testnet",
    "timeout": 15000,
    "retries": 3
  },
  "monitoring": {
    "enabled": true,
    "metrics": {
      "enabled": true,
      "port": 9090
    },
    "healthCheck": {
      "enabled": true,
      "interval": 30000
    }
  },
  "security": {
    "jwtSecret": "${JWT_SECRET}",
    "encryptionKey": "${ENCRYPTION_KEY}",
    "apiKey": "${API_KEY}"
  }
}
