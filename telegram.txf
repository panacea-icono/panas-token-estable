bot.js

import 'dotenv/config';
import { Telegraf } from 'telegraf';
import axios from 'axios';

const bot = new Telegraf(process.env.BOT_TOKEN);

// /start
bot.start((ctx) =>
  ctx.reply(`¡Bienvenido a Clínica VASER!
Comandos:
• /consulta_online (Stars)
• /consulta_presencial (TON)
• /precios
• /mis_reservas`)
);

// Catálogo
bot.command('precios', (ctx) => {
  ctx.reply(`Tarifas:
• Consulta Online 30m: 500 XTR
• Consulta Presencial: 20 TON`);
});

// Stars: invoice digital
bot.command('consulta_online', async (ctx) => {
  return ctx.sendInvoice({
    title: 'Consulta Online 30m',
    description: 'Videoconsulta de 30 minutos',
    payload: 'consulta_online_30m',
    // Para Stars no se requiere provider_token:
    provider_token: '', // vacío = Stars
    currency: 'XTR',
    prices: [{ label: 'Consulta', amount: 500 }], // 500 Stars
    need_name: true,
    need_email: true
  });
});

// TON Wallet Pay (placeholder): crear orden vía backend
bot.command('consulta_presencial', async (ctx) => {
  const chatId = ctx.chat.id;
  try {
    const { data } = await axios.post(`${process.env.PUBLIC_URL}/order/ton`, {
      product: 'consulta_presencial',
      priceTON: 20,
      chatId
    });
    // data.checkout_url: link/botón generado por tu backend/provider
    await ctx.reply(`Paga tu consulta presencial (20 TON): ${data.checkout_url}`);
  } catch (e) {
    console.error(e);
    await ctx.reply('Error generando el pago TON. Intenta de nuevo.');
  }
});

// Pre-checkout Stars
bot.on('pre_checkout_query', (ctx) => ctx.answerPreCheckoutQuery(true));

// Pago exitoso (Stars)
bot.on('successful_payment', async (ctx) => {
  const pay = ctx.message.successful_payment;
  // Notifica a tu backend para marcar reserva pagada
  try {
    await axios.post(`${process.env.PUBLIC_URL}/webhooks/telegram`, {
      chatId: ctx.chat.id,
      payload: pay.invoice_payload,
      amount: pay.total_amount,
      currency: pay.currency,
      user: ctx.from
    });
  } catch {}
  await ctx.reply('✅ Pago recibido. En breve recibirás tu enlace de agenda/ubicación.');
});

bot.launch().then(() => console.log('Bot listo'));

backend/server.js (Express muy simple)

import 'dotenv/config';
import express from 'express';
import bodyParser from 'body-parser';

const app = express();
app.use(bodyParser.json());

// Mock DB en memoria
const ORDERS = new Map();

// Crear orden TON (placeholder)
app.post('/order/ton', (req, res) => {
  const { product, priceTON, chatId } = req.body;
  const id = `ORD-${Date.now()}`;
  const checkout_url = `https://pay.example/ton/checkout?order=${id}&amount=${priceTON}`;
  ORDERS.set(id, { product, priceTON, chatId, status: 'PENDING' });
  res.json({ order_id: id, checkout_url });
});

// Webhook Telegram (Stars pagado)
app.post('/webhooks/telegram', (req, res) => {
  const { chatId, payload, amount, currency, user } = req.body;
  // aquí marcarías la cita como pagada y agendarías en Google Calendar
  console.log('STAR PAID', { chatId, payload, amount, currency, user });
  res.sendStatus(200);
});

// Webhook Wallet Pay (TON pagado) - placeholder
app.post('/webhooks/walletpay', (req, res) => {
  const { order_id, status } = req.body;
  const ord = ORDERS.get(order_id);
  if (ord && status === 'PAID') {
    ord.status = 'PAID';
    console.log('TON PAID', ord);
  }
  res.sendStatus(200);
});

const PORT = 3000;
app.listen(PORT, () => console.log(`API en :${PORT}`));

