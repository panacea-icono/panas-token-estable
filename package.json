{
  "name": "panas-token-estable-monorepo",
  "private": true,
  "version": "1.1.0",
  "scripts": {
    "audit": "node scripts/node_audit.mjs",
    "fmt": "prettier -w .",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "status": "bash scripts/gen_status.sh",
    "bootstrap": "bash scripts/bootstrap.sh",
    "audit:deps": "bash scripts/audit_deps.sh",
    "audit:env": "bash scripts/audit_env.sh",
    "test": "npm run test:backend && npm run test:frontend",
    "test:ci": "jest --config ./tests/jest.config.js --coverage --ci --runInBand",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "test:backend": "cd backend && npm test",
    "test:frontend": "cd frontend && npm test",
    "deploy": "npm run deploy:backend && npm run deploy:frontend",
    "deploy:backend": "cd backend && npm run deploy",
    "deploy:frontend": "cd frontend && npm run deploy",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "heroku:deploy": "git subtree push --prefix=backend heroku main",
    "vercel:deploy": "cd frontend && vercel --prod",
    "release": "npm run build && npm run test && npm run deploy",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "algosdk": "^2.7.0",
    "ethers": "^6.13.1",
    "tonweb": "^0.0.66",
    "axios": "^1.6.2",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.3.1",
    "mongoose": "^8.0.3",
    "redis": "^5.0.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "openai": "^4.20.1",
    "huggingface": "^0.0.8",
    "@ton/ton": "^15.0.0",
    "telegraf": "^4.15.6",
    "discord.js": "^14.14.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "next": "^14.0.4"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/winston": "^2.4.4",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.1.2",
    "prettier": "^3.1.0",
    "ts-jest": "^29.4.1",
    "typescript": "^5.6.2",
    "winston": "^3.17.0",
    "eslint": "^8.55.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "ts-node": "^10.9.2",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18"
  }
}
