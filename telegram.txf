bot.py

import os, requests
from aiogram import Bot, Dispatcher, types
from aiogram.utils import executor
from dotenv import load_dotenv
load_dotenv()

BOT_TOKEN = os.getenv("BOT_TOKEN")
PUBLIC_URL = os.getenv("PUBLIC_URL")
bot = Bot(token=BOT_TOKEN)
dp = Dispatcher(bot)

@dp.message_handler(commands=['start'])
async def start(msg: types.Message):
    await msg.answer("""¡Bienvenido a Clínica VASER!
/consulta_online  (Stars)
/consulta_presencial  (TON)
/precios
/mis_reservas""")

@dp.message_handler(commands=['precios'])
async def precios(msg: types.Message):
    await msg.answer("• Consulta Online 30m: 500 XTR\n• Consulta Presencial: 20 TON")

@dp.message_handler(commands=['consulta_online'])
async def consulta_online(msg: types.Message):
    prices = [types.LabeledPrice(label="Consulta Online 30m", amount=500)]
    await bot.send_invoice(
        chat_id=msg.chat.id,
        title="Consulta Online 30m",
        description="Videoconsulta",
        payload="consulta_online_30m",
        provider_token="",  # vacío = Stars
        currency="XTR",
        prices=prices,
        need_name=True, need_email=True
    )

@dp.pre_checkout_query_handler(lambda q: True)
async def pre_checkout(pre_q: types.PreCheckoutQuery):
    await bot.answer_pre_checkout_query(pre_q.id, ok=True)

@dp.message_handler(content_types=types.ContentTypes.SUCCESSFUL_PAYMENT)
async def paid(msg: types.Message):
    pay = msg.successful_payment
    # Notificar a tu backend
    try:
        requests.post(f"{PUBLIC_URL}/webhooks/telegram", json={
            "chatId": msg.chat.id,
            "payload": pay.invoice_payload,
            "amount": pay.total_amount,
            "currency": pay.currency,
            "user": {"id": msg.from_user.id, "name": msg.from_user.full_name}
        }, timeout=5)
    except Exception as e:
        print("Webhook error:", e)
    await msg.answer("✅ Pago recibido. Te envío el enlace de agenda/ubicación.")

@dp.message_handler(commands=['consulta_presencial'])
async def consulta_presencial(msg: types.Message):
    try:
        r = requests.post(f"{PUBLIC_URL}/order/ton", json={
            "product": "consulta_presencial",
            "priceTON": 20,
            "chatId": msg.chat.id
        }, timeout=5)
        data = r.json()
        await msg.answer(f"Paga tu consulta presencial (20 TON): {data['checkout_url']}")
    except Exception as e:
        await msg.answer("Error generando pago TON.")
        print(e)

if __name__ == "__main__":
    executor.start_polling(dp)

backend.py (FastAPI simple)

import uvicorn
from fastapi import FastAPI, Request

app = FastAPI()
ORDERS = {}

@app.post("/order/ton")
async def order_ton(payload: dict):
    order_id = f"ORD-{len(ORDERS)+1}"
    checkout_url = f"https://pay.example/ton/checkout?order={order_id}&amount={payload.get('priceTON',20)}"
    ORDERS[order_id] = {**payload, "order_id": order_id, "status":"PENDING"}
    return {"order_id": order_id, "checkout_url": checkout_url}

@app.post("/webhooks/telegram")
async def wh_telegram(body: dict):
    # Marca pagado + agenda
    print("STAR PAID:", body)
    return {"ok": True}

@app.post("/webhooks/walletpay")
async def wh_walletpay(body: dict):
    order_id = body.get("order_id")
    status = body.get("status")
    if order_id in ORDERS and status == "PAID":
        ORDERS[order_id]["status"] = "PAID"
        print("TON PAID:", ORDERS[order_id])
    return {"ok": True}

if __name__ == "__main__":
    uvicorn.run(app, host="0.0.0.0", port=3000)

